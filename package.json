{
  "name": "playwright-automation",
  "version": "1.0.0",
  "type": "module",
  "description": "Playwright + POM + Hooks + Allure automation framework for adactinhotelapp.com",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:chrome": "npx playwright test --project=chromium",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "report": "npm run report:generate && npm run report:open"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "allure-playwright": "^3.0.0",
    "allure-commandline": "^2.30.0"
  }
}
